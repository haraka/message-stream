{
  "name": "haraka-message-stream",
  "version": "2.0.1",
  "description": "Haraka email message stream",
  "main": "index.js",
  "files": [
    "CHANGELOG.md",
    "lib"
  ],
  "scripts": {
    "format": "npm run prettier:fix && npm run lint:fix",
    "lint": "npx eslint *.js test",
    "lint:fix": "npx eslint --fix *.js test",
    "prettier": "npx prettier . --check",
    "prettier:fix": "npx prettier . --write --log-level=warn",
    "test": "node --test",
    "versions": "npx npm-dep-mgr check",
    "versions:fix": "npx npm-dep-mgr update",
    "test:coverage": "npx c8 --reporter=text --reporter=text-summary npm test"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/haraka/message-stream.git"
  },
  "keywords": [
    "haraka",
    "email",
    "message-stream"
  ],
  "author": "Haraka Team <haraka.team@gmail.com>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/haraka/message-stream/issues"
  },
  "homepage": "https://github.com/haraka/message-stream#readme",
  "devDependencies": {
    "@haraka/eslint-config": "^2.0.4"
  },
  "dependencies": {},
  "prettier": {
    "singleQuote": true,
    "semi": false
  }
}